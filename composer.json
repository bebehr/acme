{
  "name": "bebehr/acme",
  "description": "A Company that Manufactures Everything",
  "license": "MIT",
  "type": "project",
  "authors": [
    {
      "name": "bebehr",
      "homepage": "https://github.com/bebehr"
    }
  ],
  "homepage": "https://github.com/bebehr/acme",
  "support": {
    "issues": "https://github.com/bebehr/acme/issues"
  },
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "bamarni/composer-bin-plugin": "^1.8",
    "ergebnis/composer-normalize": "^2.52",
    "fakerphp/faker": "^1.24",
    "phpunit/phpunit": "^11.5"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "bamarni/composer-bin-plugin": true,
      "ergebnis/composer-normalize": true
    },
    "optimize-autoloader": true,
    "platform": {
      "php": "8.2.27"
    },
    "sort-packages": true
  },
  "extra": {
    "bamarni-bin": {
      "bin-links": false,
      "forward-command": true,
      "target-directory": "tools"
    },
    "composer-normalize": {
      "indent-size": 2,
      "indent-style": "space"
    }
  },
  "scripts": {
    "fix": [
      "./tools/vendor/bin/php-cs-fixer fix -v --diff",
      "./tools/vendor/bin/phpcbf",
      "@composer normalize --diff",
      "@fix:tools"
    ],
    "fix:tools": [
      "@composer normalize --diff tools/composer.json"
    ],
    "test": [
      "@test:lint",
      "@test:analyse",
      "@test:unit",
      "@test:composer"
    ],
    "test:analyse": [
      "./tools/vendor/bin/phpcpd --exclude .ddev --exclude .vscode --exclude tools --exclude var --exclude vendor --fuzzy .",
      "./tools/vendor/bin/phpmd . html .phpmd.xml --report-file var/report/phpmd.html --exclude '*.ddev/*,*.vscode/*,*tools/*,*var/cache/*,*var/log/*,*var/report/*,*vendor/*' --cache --cache-file var/cache/.phpmd.result-cache.php --cache-strategy content --ignore-errors-on-exit --ignore-violations-on-exit",
      "./tools/vendor/bin/phpmd . ansi .phpmd.xml --exclude '*.ddev/*,*.vscode/*,*tools/*,*var/cache/*,*var/log/*,*var/report/*,*vendor/*' --cache --cache-file var/cache/.phpmd.result-cache.php --cache-strategy content",
      "./tools/vendor/bin/phpstan analyse",
      "./tools/vendor/bin/psalm --no-cache",
      "./tools/vendor/bin/psalm --no-cache --taint-analysis",
      "./tools/phpinsights/vendor/bin/phpinsights analyse -c phpinsights.php -n -v ."
    ],
    "test:composer": [
      "@composer validate --strict",
      "@composer check-platform-reqs",
      "@composer normalize --dry-run",
      "@composer audit",
      "@composer outdated --direct",
      "@test:composer:tools"
    ],
    "test:composer:tools": [
      "@composer validate --no-check-publish --working-dir=tools",
      "@composer check-platform-reqs --working-dir=tools",
      "@composer normalize --dry-run tools/composer.json",
      "@composer audit --abandoned=report --working-dir=tools",
      "@composer outdated --direct --working-dir=tools"
    ],
    "test:lint": [
      "./tools/vendor/bin/phplint",
      "./tools/vendor/bin/php-cs-fixer check -v --diff",
      "./tools/vendor/bin/phpcs"
    ],
    "test:unit": [
      "xdebug",
      "php -d xdebug.mode=coverage vendor/bin/phpunit --testsuite=Unit",
      "xdebug off"
    ]
  }
}
