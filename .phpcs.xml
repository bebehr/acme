<?xml version="1.0"?>
<ruleset
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  name="PHP_CodeSniffer Coding Standards"
  xsi:noNamespaceSchemaLocation="tools/vendor/squizlabs/php_codesniffer/phpcs.xsd"
>
  <description>Custom coding standards for PHP_CodeSniffer</description>

  <file>.</file>
  <file>.php-cs-fixer.php</file>

  <exclude-pattern>*/.ddev/*</exclude-pattern>
  <exclude-pattern>*/.vscode/*</exclude-pattern>
  <exclude-pattern>*/tools/*</exclude-pattern>
  <exclude-pattern>*/var/cache/*</exclude-pattern>
  <exclude-pattern>*/var/log/*</exclude-pattern>
  <exclude-pattern>*/var/report/*</exclude-pattern>
  <exclude-pattern>*/vendor/*</exclude-pattern>

  <arg name="basepath" value="."/>
  <arg name="cache" value="./var/cache/phpcs.cache"/>
  <arg name="colors"/>
  <arg name="parallel" value="1"/>
  <arg name="report" value="full,summary,source"/>
  <arg value="ps"/>

  <!-- Check for cross-version support for PHP 8.2 and higher. -->
  <config name="testVersion" value="8.2-"/>
  <!-- Run against the PHPCompatibility ruleset -->
  <rule ref="PHPCompatibility"/>

  <!-- Include the whole PSR-12 standard -->
  <rule ref="PSR12">
    <!-- PER-CS: single_line_empty_body -->
    <exclude name="PSR2.Classes.ClassDeclaration.OpenBraceNewLine"/>
    <exclude name="Squiz.Functions.MultiLineFunctionDeclaration.BraceOnSameLine"/>
    <exclude name="Squiz.WhiteSpace.ScopeClosingBrace.ContentBefore"/>
  </rule>

  <!-- Lines can be 80 chars long, show errors at 120 chars -->
  <rule ref="Generic.Files.LineLength">
    <properties>
      <property name="lineLimit" value="80"/>
      <property name="absoluteLineLimit" value="120"/>
    </properties>
  </rule>
</ruleset>
